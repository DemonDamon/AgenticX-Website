# Supabase (Auth + optional Postgres; can use same project DB as DATABASE_URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Drizzle / device auth table (Supabase → Settings → Database → URI, use pooler if on Vercel)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# 正式站点根 URL（不要尾斜杠）。注册确认邮件会跳回 `${NEXT_PUBLIC_SITE_URL}/auth`；
# 不配则退回「当前浏览器 origin」；Supabase 后台 Site URL 也需改为同一生产域名。
NEXT_PUBLIC_SITE_URL=https://www.agxbuilder.com
