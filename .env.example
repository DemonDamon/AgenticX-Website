# Supabase (Auth + optional Postgres; can use same project DB as DATABASE_URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Drizzle / device auth table (Supabase → Settings → Database → URI, use pooler if on Vercel)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Public site URL (used in deep links; production: https://www.agxbuilder.com)
NEXT_PUBLIC_SITE_URL=http://localhost:5000
